# Database
DATABASE_URL="postgresql://user:password@localhost:5432/hampi-stays-db?schema=public"

# Auth
JWT_SECRET="your_jwt_secret_key"

# Google OAuth
# Get these from Google Cloud Console: https://console.cloud.google.com/
GOOGLE_CLIENT_ID="your_google_client_id.apps.googleusercontent.com"
VITE_GOOGLE_CLIENT_ID="your_google_client_id.apps.googleusercontent.com"

# Apple OAuth
# Get these from Apple Developer Portal: https://developer.apple.com/
APPLE_CLIENT_ID="your.apple.service.id"
VITE_APPLE_CLIENT_ID="your.apple.service.id"

# Cloudinary Config
# Get these from Cloudinary Dashboard: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"
