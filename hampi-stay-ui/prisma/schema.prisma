generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  name             String
  passwordHash     String
  role             Role              @default(TRAVELLER)
  avatar           String?
  phone            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  idImage          String?
  idNumber         String?
  idType           String?
  isEmailVerified  Boolean           @default(false)
  isMobileVerified Boolean           @default(false)
  kycStatus        String?           @default("NOT_SUBMITTED")
  location         String?
  bookings         Booking[]
  guideBookings    GuideBooking[]
  guideProfile     GuideProfile?
  messages         Message[]
  notifications    Notification[]
  otpVerifications OtpVerification[]
  ownerProfile     ResortOwner?
  reviews          Review[]
  staffProfile     StaffMember?
  wishlist         Wishlist[]

  @@map("users")
}

model OtpVerification {
  id        String   @id @default(cuid())
  userId    String?
  email     String?
  phone     String?
  otpHash   String
  otpType   String
  expiresAt DateTime
  verified  Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("otp_verifications")
}

model Resort {
  id             String         @id @default(cuid())
  slug           String         @unique
  name           String
  tagline        String
  description    String
  type           String
  locationArea   String
  locationLat    Float
  locationLng    Float
  images         String[]
  amenities      String[]
  rating         Float          @default(0)
  reviewCount    Int            @default(0)
  pricePerNight  Float
  isFeatured     Boolean        @default(false)
  isVerified     Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  ownerId        String
  category       String?
  houseRules     String[]
  mealPackages   Json?
  status         ResortStatus   @default(PENDING)
  commissionRate Float          @default(7.0)
  bookings       Booking[]
  discountCodes  DiscountCode[]
  invitations    Invitation[]
  owner          ResortOwner    @relation(fields: [ownerId], references: [id])
  reviews        Review[]
  roomTypes      Room[]
  staff          StaffMember[]
  wishlist       Wishlist[]

  @@map("resorts")
}

model Room {
  id             String              @id @default(cuid())
  name           String
  description    String
  pricePerNight  Float
  capacity       Int
  amenities      String[]
  images         String[]
  availableCount Int
  resortId       String
  maxNights      Int                 @default(30)
  minNights      Int                 @default(1)
  bookings       Booking[]
  blockings      RoomBlocking[]
  priceOverrides RoomPriceOverride[]
  resort         Resort              @relation(fields: [resortId], references: [id], onDelete: Cascade)

  @@map("rooms")
}

model RoomPriceOverride {
  id        String   @id @default(cuid())
  date      DateTime
  price     Float
  minNights Int?
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, date])
  @@map("room_price_overrides")
}

model SystemSettings {
  id                  String   @id @default(cuid())
  guideServiceEnabled Boolean  @default(true)
  updatedAt           DateTime @updatedAt
}

model RoomBlocking {
  id     String   @id @default(cuid())
  date   DateTime
  reason String?
  roomId String
  room   Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, date])
  @@map("room_blockings")
}

model DiscountCode {
  id               String   @id @default(cuid())
  code             String   @unique
  percentage       Float?
  flatAmount       Float?
  minBookingAmt    Float?
  validFrom        DateTime
  validUntil       DateTime
  maxUses          Int?
  usedCount        Int      @default(0)
  isEarlyBird      Boolean  @default(false)
  minDaysInAdvance Int?
  isLastMinute     Boolean  @default(false)
  maxDaysInAdvance Int?
  resortId         String
  resort           Resort   @relation(fields: [resortId], references: [id], onDelete: Cascade)

  @@map("discount_codes")
}

model Booking {
  id              String        @id @default(cuid())
  checkIn         DateTime
  checkOut        DateTime
  guests          Int
  totalPrice      Float
  status          BookingStatus @default(PENDING)
  specialRequests String?
  referenceNumber String        @unique
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  userId          String
  resortId        String
  roomId          String?
  commissionRate  Float         @default(7.0)
  resort          Resort        @relation(fields: [resortId], references: [id])
  room            Room?         @relation(fields: [roomId], references: [id])
  user            User          @relation(fields: [userId], references: [id])
  messages        Message[]

  @@map("bookings")
}

model Wishlist {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String
  resortId  String
  resort    Resort   @relation(fields: [resortId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, resortId])
  @@map("wishlist")
}

model Review {
  id        String   @id @default(cuid())
  rating    Int      @default(5)
  comment   String?
  images    String[]
  createdAt DateTime @default(now())
  userId    String
  resortId  String
  resort    Resort   @relation(fields: [resortId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model ResortOwner {
  id           String   @id @default(cuid())
  businessName String?
  gstNumber    String?
  isVerified   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resorts      Resort[]

  @@map("resort_owners")
}

model GuideProfile {
  id              String         @id @default(cuid())
  bio             String
  specialties     String[]
  languages       String[]
  pricePerDay     Float
  pricePerHour    Float
  yearsExperience Int
  isVerified      Boolean        @default(false)
  rating          Float          @default(0)
  reviewCount     Int            @default(0)
  images          String[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  userId          String         @unique
  idImage         String?
  idNumber        String?
  idType          String?
  status          ResortStatus   @default(PENDING)
  isActive        Boolean        @default(true)
  experiences     Experience[]
  bookings        GuideBooking[]
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("guide_profiles")
}

model GuideBooking {
  id              String        @id @default(cuid())
  date            DateTime
  durationHours   Int
  totalPrice      Float
  status          BookingStatus @default(PENDING)
  meetingPoint    String
  specialRequests String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  userId          String
  guideId         String
  guide           GuideProfile  @relation(fields: [guideId], references: [id])
  user            User          @relation(fields: [userId], references: [id])

  @@map("guide_bookings")
}

model Experience {
  id            String       @id @default(cuid())
  title         String
  description   String
  price         Float
  durationHours Int
  images        String[]
  meetingPoint  String
  includes      String[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  guideId       String
  guide         GuideProfile @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@map("experiences")
}

model Message {
  id        String   @id @default(cuid())
  text      String
  senderId  String
  bookingId String
  createdAt DateTime @default(now())
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  sender    User     @relation(fields: [senderId], references: [id])

  @@map("messages")
}

model StaffMember {
  id        String   @id @default(cuid())
  role      String
  resortId  String
  userId    String   @unique
  createdAt DateTime @default(now())
  resort    Resort   @relation(fields: [resortId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("staff_members")
}

model Invitation {
  id        String   @id @default(cuid())
  email     String
  role      String
  resortId  String
  code      String   @unique
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  resort    Resort   @relation(fields: [resortId], references: [id], onDelete: Cascade)

  @@map("invitations")
}

enum Role {
  TRAVELLER
  RESORT_OWNER
  ADMIN
  GUIDE
  STAFF
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum ResortStatus {
  PENDING
  APPROVED
  REJECTED
}
